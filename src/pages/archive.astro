---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchiveFilter from '../components/ArchiveFilter.astro';

const cases = (await getCollection('cases')).sort((a, b) => {
  const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (dateDiff !== 0) return dateDiff;
  return b.data.caseId.localeCompare(a.data.caseId);
});

const items = cases.map((c) => ({
  caseId: c.data.caseId,
  title: c.data.title,
  summary: c.data.summary,
  difficulty: c.data.difficulty,
  types: c.data.types,
  scene: c.data.scene,
  readingTime: c.data.readingTime,
  status: c.data.status,
  slug: c.id,
  publishedAt: c.data.publishedAt,
}));
---

<BaseLayout
  title="档案馆｜Inferred"
  description="所有案卷都会归档于此。按时间、难度、类型与场景筛选，找到下一桩等待被推断的谜案。"
  path="/archive"
>
  <section class="container page-head">
    <p class="eyebrow">Archive · 档案馆</p>
    <h1><span class="i18n-zh">档案馆</span><span class="i18n-en">Archive</span></h1>
    <p class="page-head__lead text-muted">
      <span class="i18n-zh">所有案卷都会归档于此。<br />有些已经揭晓真相。有些仍等待被推断。</span>
      <span class="i18n-en">All cases are archived here.<br />Some have been solved. Some still await deduction.</span>
    </p>
  </section>

  <section class="container archive-section">
    <ArchiveFilter cases={items} />
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .page-head__lead {
    max-width: var(--measure);
    font-size: 1.05rem;
  }
  .archive-section {
    padding-bottom: var(--space-12);
  }
</style>
