---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('clues')).sort((a, b) => {
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});
---

<BaseLayout
  title="线索｜推理技巧 · Inferred"
  description="如何识别证词矛盾、密室诡计的常见类型、不可靠叙述者……一组帮助你更会推理的文章。"
  path="/clues"
>
  <section class="container page-head">
    <p class="eyebrow">Clues · 线索</p>
    <h1>线索</h1>
    <p class="page-head__lead text-muted">
      推理是可以练习的。这里收录帮助你更会读案卷的技巧。
    </p>
  </section>

  <section class="container clues-section">
    <ul class="clue-list">
      {articles.map((a) => {
        const dateStr = a.data.publishedAt.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li>
            <a class="clue-card" href={`/clues/${a.id}`}>
              <h2 class="clue-card__title">{a.data.title}</h2>
              <p class="clue-card__summary text-muted">{a.data.summary}</p>
              <span class="clue-card__meta mono text-muted">{dateStr}</span>
              <span class="clue-card__cta mono">阅读 →</span>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .page-head__lead {
    max-width: var(--measure);
    font-size: 1.05rem;
  }
  .clues-section {
    padding-bottom: var(--space-12);
  }
  .clue-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 24rem), 1fr));
    gap: var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .clue-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .clue-card:hover {
    border-color: color-mix(in srgb, var(--color-gold) 40%, var(--color-line));
    transform: translateY(-2px);
  }
  .clue-card__title {
    font-size: 1.2rem;
    margin: 0;
  }
  .clue-card__summary {
    margin: 0;
    font-size: 0.95rem;
    flex: 1;
  }
  .clue-card__meta {
    font-size: 0.75rem;
    margin: 0;
  }
  .clue-card__cta {
    color: var(--color-gold);
    font-size: 0.85rem;
  }
</style>
