---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import ShareBar from '../../components/ShareBar.astro';

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection('clues');
  const sorted = [...articles].sort(
    (a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime()
  );
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const publishedIso = entry.data.publishedAt.toISOString();
const dateStr = entry.data.publishedAt.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const shareImage = `/og/clues/${entry.id}.jpg`;
const siteOrigin = Astro.site ?? 'https://inferred.uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: publishedIso,
  image: new URL(shareImage, siteOrigin).href,
  url: new URL(`/clues/${entry.id}`, siteOrigin).href,
  author: { '@type': 'Organization', name: 'Inferred' },
  publisher: { '@type': 'Organization', name: 'Inferred' },
};
---

<BaseLayout
  title={`${entry.data.title}｜Inferred 线索`}
  ogTitle={`${entry.data.title} · Inferred`}
  description={entry.data.summary}
  path={`/clues/${entry.id}`}
  ogImage={shareImage}
  ogImageAlt={`推理技巧：${entry.data.title}`}
  ogType="article"
  publishedTime={publishedIso}
  jsonLd={jsonLd}
>
  <article class="container container--reading clue">
    <ReadingProgress target="#clue-body" />

    <header class="clue__header">
      <p class="eyebrow">Clues · 推理技巧</p>
      <h1>{entry.data.title}</h1>
      <p class="clue__summary text-muted">{entry.data.summary}</p>
      <p class="mono text-muted clue__date">{dateStr}</p>
    </header>

    <div id="clue-body" class="prose">
      <Content />
    </div>

    <ShareBar title={entry.data.title} text={entry.data.summary} path={`/clues/${entry.id}`} />

    <nav class="clue__nav" aria-label="线索导航">
      {
        prev ? (
          <a class="clue__nav-link" href={`/clues/${prev.id}`}>
            <span class="clue__nav-dir mono">上一篇</span>
            <span class="clue__nav-title">{prev.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a class="clue__nav-link clue__nav-link--next" href={`/clues/${next.id}`}>
            <span class="clue__nav-dir mono">下一篇</span>
            <span class="clue__nav-title">{next.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>

    <footer class="clue__footer">
      <a class="clue__back" href="/clues">← 返回线索</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .clue {
    padding-top: var(--space-16);
  }
  .clue__header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-line);
  }
  .clue__summary {
    font-size: 1.1rem;
    margin: var(--space-3) 0;
  }
  .clue__date {
    font-size: 0.78rem;
    margin: 0;
  }
  .clue__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-line);
  }
  .clue__nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-paper);
    transition: border-color 0.18s ease;
  }
  .clue__nav-link:hover {
    border-color: var(--color-gold);
    color: var(--color-paper);
  }
  .clue__nav-link--next {
    text-align: right;
  }
  .clue__nav-dir {
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }
  .clue__nav-title {
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .clue__footer {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-line);
  }
  .clue__back {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .clue__back:hover {
    color: var(--color-gold);
  }
  @media (max-width: 560px) {
    .clue__nav {
      grid-template-columns: 1fr;
    }
    .clue__nav-link--next {
      text-align: left;
    }
  }
</style>
