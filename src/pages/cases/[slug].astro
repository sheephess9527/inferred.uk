---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseMeta from '../../components/CaseMeta.astro';
import Tag from '../../components/Tag.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import ShareBar from '../../components/ShareBar.astro';
import HintSystem from '../../components/HintSystem.astro';
import DifficultyVote from '../../components/DifficultyVote.astro';
import RelatedCases from '../../components/RelatedCases.astro';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  const sorted = [...cases].sort(
    (a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime()
  );
  return sorted.map((entry, i) => {
    const related = cases
      .filter((c) => c.id !== entry.id)
      .map((c) => ({
        c,
        score: c.data.types.filter((t) => entry.data.types.includes(t)).length,
      }))
      .sort(
        (a, b) =>
          b.score - a.score ||
          b.c.data.publishedAt.getTime() - a.c.data.publishedAt.getTime()
      )
      .slice(0, 3)
      .map(({ c }) => ({
        caseId: c.data.caseId,
        title: c.data.title,
        types: c.data.types,
        difficulty: c.data.difficulty,
        status: c.data.status,
        readingTime: c.data.readingTime,
        slug: c.id,
      }));

    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: i > 0 ? sorted[i - 1] : null,
        next: i < sorted.length - 1 ? sorted[i + 1] : null,
        related,
      },
    };
  });
}

const { entry, prev, next, related } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const seoTitle = `${data.title}｜Inferred Case File #${data.caseId}`;
const shareTitle = `${data.title} · Inferred`;
const seoDesc = data.summary;
const shareImage = `/og/cases/${entry.id}.jpg`;
const shareImageAlt = `案卷 ${data.caseId}：${data.title}`;
const publishedIso = data.publishedAt.toISOString();
const dateStr = data.publishedAt.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const siteOrigin = Astro.site ?? 'https://inferred.uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.summary,
  datePublished: publishedIso,
  image: new URL(shareImage, siteOrigin).href,
  url: new URL(`/cases/${entry.id}`, siteOrigin).href,
  author: { '@type': 'Organization', name: 'Inferred' },
  publisher: { '@type': 'Organization', name: 'Inferred' },
};
---

<BaseLayout
  title={seoTitle}
  ogTitle={shareTitle}
  description={seoDesc}
  path={`/cases/${entry.id}`}
  ogImage={shareImage}
  ogImageAlt={shareImageAlt}
  ogType="article"
  publishedTime={publishedIso}
  jsonLd={jsonLd}
>
  <article class="case container container--reading">
    <ReadingProgress target="#case-body" />

    <header class="case__header">
      <p class="eyebrow case__eyebrow" data-case-eyebrow data-case-slug={entry.id} data-site-status={data.status}>
        Case File #{data.caseId} · <span data-case-eyebrow-text>{data.status === 'solved' ? 'Solved' : 'Unsolved'}</span>
      </p>
      <h1 class="case__title">{data.title}</h1>
      <p class="case__summary">{data.summary}</p>

      <ul class="case__tags">
        {data.types.map((t) => (
          <li>
            <Tag
              label={t}
              href={`/archive?type=${encodeURIComponent(t)}`}
            />
          </li>
        ))}
        {data.scene.map((s) => (
          <li>
            <Tag
              label={s}
              variant="scene"
              href={`/archive?scene=${encodeURIComponent(s)}`}
            />
          </li>
        ))}
      </ul>

      <CaseMeta
        caseId={data.caseId}
        slug={entry.id}
        status={data.status}
        difficulty={data.difficulty}
        types={data.types}
        readingTime={data.readingTime}
        clueCount={data.clueCount}
      />
      <p class="case__published mono text-muted">归档于 {dateStr}</p>
    </header>

    {data.hints && data.hints.length > 0 && (
      <HintSystem hints={data.hints} />
    )}

    <div id="case-body" class="case__body prose">
      <Content />
    </div>

    <DifficultyVote slug={entry.id} officialDifficulty={data.difficulty} />

    <ShareBar
      title={data.title}
      text={data.summary}
      path={`/cases/${entry.id}`}
      poster={`/share/cases/${entry.id}.jpg`}
    />

    <RelatedCases cases={related} />

    <nav class="case__nav" aria-label="案卷导航">
      {prev ? (
        <a class="case__nav-link" href={`/cases/${prev.id}`}>
          <span class="case__nav-dir mono">上一篇</span>
          <span class="case__nav-title">{prev.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}
      {next ? (
        <a class="case__nav-link case__nav-link--next" href={`/cases/${next.id}`}>
          <span class="case__nav-dir mono">下一篇</span>
          <span class="case__nav-title">{next.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}
    </nav>

    <footer class="case__footer">
      <a class="case__back" href="/cases">← 返回案卷列表</a>
      <a class="case__back" href="/archive">进入档案馆 →</a>
    </footer>
  </article>
</BaseLayout>

<script is:inline define:vars={{ caseSlug: entry.id, siteStatus: data.status }}>
  function syncEyebrow() {
    var eyebrow = document.querySelector('[data-case-eyebrow]');
    var text = eyebrow && eyebrow.querySelector('[data-case-eyebrow-text]');
    if (!text) return;
    try {
      var p = localStorage.getItem('inferred:progress:/cases/' + caseSlug);
      if (p === 'solved') text.textContent = 'Closed · 已结案';
      else if (p === 'reading') text.textContent = 'Active · 推理中';
      else text.textContent = siteStatus === 'solved' ? 'Solved' : 'Unsolved';
    } catch (_) {}
  }
  try {
    var key = 'inferred:progress:/cases/' + caseSlug;
    if (localStorage.getItem(key) !== 'solved') {
      localStorage.setItem(key, 'reading');
    }
  } catch (_) {}
  syncEyebrow();
  window.addEventListener('inferred:case-solved', syncEyebrow);
</script>

<style>
  .case {
    padding-top: var(--space-12);
  }
  .case__header {
    margin-bottom: var(--space-8);
  }
  .case__eyebrow {
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }
  .case__title {
    margin-bottom: var(--space-4);
  }
  .case__summary {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: var(--space-6);
  }
  .case__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-6);
    padding: 0;
    list-style: none;
  }
  .case__published {
    margin: var(--space-3) 0 0;
    font-size: 0.78rem;
  }
  .case__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-line);
  }
  .case__nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-paper);
    transition: border-color 0.18s ease;
  }
  .case__nav-link:hover {
    border-color: var(--color-gold);
    color: var(--color-paper);
  }
  .case__nav-link--next {
    text-align: right;
  }
  .case__nav-dir {
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.1em;
  }
  .case__nav-title {
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .case__footer {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-line);
  }
  .case__back {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .case__back:hover {
    color: var(--color-gold);
  }

  @media (max-width: 560px) {
    .case__nav {
      grid-template-columns: 1fr;
    }
    .case__nav-link--next {
      text-align: left;
    }
  }
</style>

<style is:global>
  /* 案卷正文排版 */
  .prose h2 {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-line);
  }
  .prose h2::before {
    content: '§ ';
    color: var(--color-accent);
    font-family: var(--font-mono);
  }
  .prose h3 {
    color: var(--color-gold);
  }
  .prose ol,
  .prose ul {
    padding-left: 1.4em;
  }
  .prose li {
    margin-bottom: var(--space-2);
  }
  .prose blockquote {
    margin: var(--space-4) 0;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-accent-cold);
    color: var(--color-muted);
    font-style: italic;
  }
  .prose strong {
    color: var(--color-paper);
  }
</style>
