---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseList from '../../components/CaseList.astro';

const cases = (await getCollection('cases')).sort(
  (a, b) => {
  const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
  if (dateDiff !== 0) return dateDiff;
  return b.data.caseId.localeCompare(a.data.caseId);
}
);

const items = cases.map((c) => ({
  caseId: c.data.caseId,
  title: c.data.title,
  summary: c.data.summary,
  difficulty: c.data.difficulty,
  types: c.data.types,
  readingTime: c.data.readingTime,
  status: c.data.status,
  slug: c.id,
}));
---

<BaseLayout
  title="案卷列表｜Inferred"
  description="所有原创互动推理案卷。阅读案卷，分析证词，找出矛盾，在答案揭晓前推断真相。"
  path="/cases"
>
  <section class="container page-head">
    <p class="eyebrow">Cases · 案卷</p>
    <h1>案卷列表</h1>
    <p class="page-head__lead text-muted">
      一份份案卷，有的已解，有的仍待推断。挑一桩，开始阅读。
    </p>
  </section>

  <section class="container">
    <CaseList cases={items} />
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }
  .page-head__lead {
    max-width: var(--measure);
    font-size: 1.05rem;
  }
</style>
