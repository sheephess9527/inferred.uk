---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseList from '../components/CaseList.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import ProgressDashboard from '../components/ProgressDashboard.astro';
import BrandMark from '../components/BrandMark.astro';

const allCases = (await getCollection('cases')).sort(
  (a, b) => {
    const dateDiff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
    if (dateDiff !== 0) return dateDiff;
    return b.data.caseId.localeCompare(a.data.caseId);
  }
);

const featuredCases = allCases.filter((c) => c.data.featured);
const showcase = featuredCases.length ? featuredCases : allCases;
const showcaseCount = showcase.length;
const latest = showcase.slice(0, 10).map((c) => ({
  caseId: c.data.caseId,
  title: c.data.title,
  summary: c.data.summary,
  difficulty: c.data.difficulty,
  types: c.data.types,
  readingTime: c.data.readingTime,
  status: c.data.status,
  slug: c.id,
}));

const steps = [
  {
    n: '01',
    title: '阅读案卷',
    body: '查看人物、证词、物证和时间线。',
  },
  {
    n: '02',
    title: '找出矛盾',
    body: '注意那些被轻轻带过，却不该出现的细节。',
  },
  {
    n: '03',
    title: '推断真相',
    body: '在答案揭晓前，写下你的判断。',
  },
];

const caseTypes = [
  { label: '密室', desc: '门窗反锁，凶手却已离开。' },
  { label: '不在场证明', desc: '每个人都说自己当时在别处。' },
  { label: '时间线诡计', desc: '真相藏在事件发生的顺序里。' },
  { label: '证词矛盾', desc: '有人多说了一个不该知道的细节。' },
  { label: '叙述性诡计', desc: '你读到的，未必是事情的全貌。' },
  { label: '物证误导', desc: '最显眼的线索，往往是设给你的。' },
];
---

<BaseLayout
  title="推知 Inferred｜原创互动悬疑推理案卷"
  description="推知 Inferred 是一个原创互动推理网站。真相从不明说，只能被推断——阅读案卷，分析证词，找出矛盾，在答案揭晓前推断真相。"
  path="/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__brand">
        <BrandMark class="hero__logo" size={68} title="推知 Inferred" />
        <span class="hero__brand-name">
          <span class="hero__brand-cn">推知</span>
          <span class="hero__brand-en">Inferred</span>
        </span>
      </div>
      <p class="eyebrow hero__eyebrow">The truth is never stated. It is inferred.</p>
      <h1 class="hero__title">真相从不明说，<br />只能被推断。</h1>
      <p class="hero__subtitle">
        不是被告知，而是自己看见。<br />
        阅读案卷，分析证词，找出矛盾，在答案揭晓前推断真相。
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/cases">开始推理</a>
        <a class="btn btn--ghost" href="/archive">进入档案馆</a>
      </div>
    </div>
    <div class="hero__rule" aria-hidden="true"></div>
  </section>

  <!-- 介绍 -->
  <section class="container intro">
    <p class="intro__text">
      一份份悬疑案卷。<br />
      一段段彼此矛盾的证词。<br />
      一些看似无关的线索。<br />
      你要做的，不是阅读故事。<br />
      你要做的，<strong>是推断它们之间真正的关系。</strong>
    </p>
  </section>

  <!-- 精选案卷 -->
    <ProgressDashboard totalCases={allCases.length} client:load />
  <section class="container section">
    <header class="section__head">
      <div>
        <p class="eyebrow">Featured Cases</p>
        <h2 class="section__title">精选案卷</h2>
        <p class="section__count text-muted mono">共 {showcaseCount} 份</p>
      </div>
      <div class="section__head-right">
        <div class="user-progress" data-user-progress data-total={allCases.length} hidden>
          <span class="user-progress__label mono" data-progress-label></span>
          <div class="user-progress__bar" aria-hidden="true">
            <div class="user-progress__fill" data-progress-fill></div>
          </div>
        </div>
        <a class="section__more" href="/cases">查看全部 →</a>
      </div>
    </header>
    <CaseList cases={latest} />
  </section>

  <!-- 玩法说明 -->
  <section class="how">
    <div class="container">
      <header class="section__head">
        <div>
          <p class="eyebrow">How It Works</p>
          <h2 class="section__title">三步，从线索到真相</h2>
        </div>
      </header>
      <ol class="how__steps">
        {steps.map((s) => (
          <li class="how__step">
            <span class="how__num mono">{s.n}</span>
            <h3 class="how__step-title">{s.title}</h3>
            <p class="how__step-body text-muted">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- 案件类型 -->
    <ProgressDashboard totalCases={allCases.length} client:load />
  <section class="container section">
    <header class="section__head">
      <div>
        <p class="eyebrow">Case Types</p>
        <h2 class="section__title">你会遇到的诡计</h2>
      </div>
      <a class="section__more" href="/archive">按类型浏览 →</a>
    </header>
    <ul class="types">
      {caseTypes.map((t) => (
        <li class="types__item">
          <a class="types__link" href={`/archive?type=${encodeURIComponent(t.label)}`}>
            <span class="types__label">{t.label}</span>
            <span class="types__desc text-muted">{t.desc}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- 订阅 -->
    <ProgressDashboard totalCases={allCases.length} client:load />
  <section class="container section">
    <NewsletterBox />
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
    position: relative;
  }
  .hero__inner {
    max-width: var(--measure-wide);
  }
  .hero__brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }
  .hero__logo {
    flex-shrink: 0;
    display: block;
  }
  .hero__brand-name {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .hero__brand-cn {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.9rem;
    letter-spacing: 0.12em;
    color: var(--color-paper);
  }
  .hero__brand-en {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .hero__eyebrow {
    margin-bottom: var(--space-6);
  }
  .hero__title {
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 var(--space-6);
    letter-spacing: 0.01em;
  }
  .hero__subtitle {
    font-size: clamp(1.05rem, 2.4vw, 1.3rem);
    color: var(--color-muted);
    max-width: 34rem;
    margin: 0 0 var(--space-8);
  }
  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero__rule {
    margin-top: var(--space-16);
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      var(--color-line) 40%,
      transparent
    );
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    padding: 0.8em 1.6em;
    border-radius: var(--radius);
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .btn--primary {
    background: var(--color-accent);
    color: var(--color-paper);
    border-color: var(--color-accent);
  }
  .btn--primary:hover {
    background: color-mix(in srgb, var(--color-accent) 80%, black);
    color: var(--color-paper);
  }
  .btn--ghost {
    border-color: var(--color-line);
    color: var(--color-paper);
  }
  .btn--ghost:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  /* 介绍 */
  .intro {
    padding-block: var(--space-16);
  }
  .intro__text {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3.2vw, 2rem);
    line-height: 1.7;
    max-width: var(--measure);
  }
  .intro__text strong {
    color: var(--color-gold);
    font-weight: 600;
  }

  /* 通用 section */
  .section {
    padding-block: var(--space-12);
  }
  .section__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }
  .section__title {
    margin: var(--space-2) 0 0;
  }
  .section__count {
    margin: var(--space-2) 0 0;
    font-size: 0.78rem;
  }
  .section__more {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .section__more:hover {
    color: var(--color-gold);
  }

  /* How it works */
  .how {
    background: var(--color-surface);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    padding-block: var(--space-16);
  }
  .how__steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: var(--space-8);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .how__step {
    border-top: 2px solid var(--color-accent);
    padding-top: var(--space-4);
  }
  .how__num {
    font-size: 1.4rem;
    color: var(--color-accent);
  }
  .how__step-title {
    margin: var(--space-3) 0 var(--space-2);
  }
  .how__step-body {
    margin: 0;
  }

  /* 案件类型 */
  .types {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-line);
  }
  .types__item {
    background: var(--color-surface);
  }
  .types__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-6);
    color: inherit;
    height: 100%;
    transition: background 0.18s ease;
  }
  .types__link:hover {
    color: inherit;
    background: var(--color-surface-2);
  }
  .types__label {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-paper);
  }
  .types__desc {
    font-size: 0.9rem;
  }

  .section__head-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }
  .user-progress {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
  }
  .user-progress__label {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .user-progress__bar {
    width: 7rem;
    height: 3px;
    background: var(--color-line);
    border-radius: 2px;
    overflow: hidden;
  }
  .user-progress__fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent), #6abf8a);
    border-radius: 2px;
    transition: width 0.4s ease;
  }
</style>

<script>
  const el = document.querySelector<HTMLElement>('[data-user-progress]');
  if (el) {
    const total = Number(el.dataset.total) || 0;
    let solved = 0;
    let reading = 0;
    try {
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k?.startsWith('inferred:progress:')) {
          const v = localStorage.getItem(k);
          if (v === 'solved') solved++;
          else if (v === 'reading') reading++;
        }
      }
    } catch (_) {}
    if (solved > 0 || reading > 0) {
      el.removeAttribute('hidden');
      const label = el.querySelector('[data-progress-label]');
      const fill = el.querySelector<HTMLElement>('[data-progress-fill]');
      if (label) {
        label.textContent = solved > 0
          ? `已结案 ${solved}${reading > 0 ? ` · 推理中 ${reading}` : ''} / ${total}`
          : `推理中 ${reading} / ${total}`;
      }
      if (fill) {
        fill.style.width = `${Math.min(100, Math.round((solved / total) * 100))}%`;
      }
    }
  }
</script>
