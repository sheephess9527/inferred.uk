---
// 侦探工作台 - 基础分屏容器
---

<div class="detective-desk" data-detective-desk>
  <div class="desk-main">
    <slot name="main" />
  </div>
  <div class="desk-sidebar">
    <div class="desk-sidebar__section">
      <h4 class="desk-sidebar__title">物证</h4>
      <slot name="evidence" />
    </div>
    <div class="desk-sidebar__section">
      <h4 class="desk-sidebar__title">侦探笔记</h4>
      <slot name="notes" />
    </div>
  </div>
</div>

<style>
  .detective-desk {
    display: none;
  }

  body.desk-mode .detective-desk {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-8);
    align-items: start;
  }

  .desk-main {
    min-width: 0;
  }

  .desk-sidebar {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .desk-sidebar__section {
    margin-bottom: var(--space-8);
  }

  .desk-sidebar__title {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-line);
  }
</style>
