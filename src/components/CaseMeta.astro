---
import DifficultyStars from './DifficultyStars.astro';

export interface Props {
  caseId: string;
  slug: string;
  status: 'unsolved' | 'solved';
  difficulty: number;
  types: string[];
  readingTime: string;
  clueCount?: number;
}
const { caseId, slug, status, difficulty, types, readingTime, clueCount } = Astro.props;
const statusCn = status === 'solved' ? '已解' : '未解';
const statusEn = status === 'solved' ? 'SOLVED' : 'UNSOLVED';
const typeEn = types.join(' / ');
---

<dl class="case-meta">
  <div class="case-meta__row">
    <dt><span class="i18n-zh">案卷编号</span><span class="i18n-en">Case</span></dt>
    <dd class="mono">CASE FILE #{caseId}</dd>
  </div>
  <div class="case-meta__row">
    <dt><span class="i18n-zh">状态</span><span class="i18n-en">Status</span></dt>
    <dd data-case-progress data-case-slug={slug} data-site-status={status}>
      <span class:list={['mono', 'case-meta__status', `is-${status}`]} data-case-progress-en
        >{statusEn}</span
      >
      <span class="text-muted i18n-zh" data-case-progress-cn>· {statusCn}</span>
    </dd>
  </div>
  <div class="case-meta__row">
    <dt><span class="i18n-zh">难度</span><span class="i18n-en">Difficulty</span></dt>
    <dd><DifficultyStars value={difficulty} showLabel /></dd>
  </div>
  <div class="case-meta__row">
    <dt><span class="i18n-zh">类型</span><span class="i18n-en">Type</span></dt>
    <dd>{typeEn}</dd>
  </div>
  <div class="case-meta__row">
    <dt><span class="i18n-zh">推理时间</span><span class="i18n-en">Est. Time</span></dt>
    <dd class="mono">{readingTime}</dd>
  </div>
  {
    typeof clueCount === 'number' && clueCount > 0 && (
      <div class="case-meta__row">
        <dt><span class="i18n-zh">线索数量</span><span class="i18n-en">Clues</span></dt>
        <dd class="mono">{clueCount}</dd>
      </div>
    )
  }
</dl>

<style>
  .case-meta {
    margin: 0;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: var(--space-4) var(--space-6);
  }
  .case-meta__row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: var(--space-4);
    padding: var(--space-2) 0;
    border-bottom: 1px dashed var(--color-line);
  }
  .case-meta__row:last-child {
    border-bottom: none;
  }
  dt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    align-self: center;
  }
  dd {
    margin: 0;
    align-self: center;
  }
  .case-meta__status.is-unsolved {
    color: var(--color-accent);
  }
  .case-meta__status.is-solved {
    color: var(--color-gold);
  }
  .case-meta__status.is-reading {
    color: #e8a84c;
  }
  .case-meta__status.is-user-solved {
    color: #6abf8a;
  }
  @media (max-width: 460px) {
    .case-meta__row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>

<script>
  function updateCaseProgressBadge(root: HTMLElement) {
    const slug = root.dataset.caseSlug;
    const en = root.querySelector<HTMLElement>('[data-case-progress-en]');
    const cn = root.querySelector<HTMLElement>('[data-case-progress-cn]');
    if (!slug || !en || !cn) return;

    const siteSolved = root.dataset.siteStatus === 'solved';
    let progress: string | null = null;
    try {
      progress = localStorage.getItem(`inferred:progress:/cases/${slug}`);
    } catch (_) {}

    if (progress === 'solved') {
      en.textContent = 'CLOSED';
      en.className = 'mono case-meta__status is-user-solved';
      cn.textContent = '· 已结案';
    } else if (progress === 'reading') {
      en.textContent = 'ACTIVE';
      en.className = 'mono case-meta__status is-reading';
      cn.textContent = '· 推理中';
    } else if (siteSolved) {
      en.textContent = 'SOLVED';
      en.className = 'mono case-meta__status is-solved';
      cn.textContent = '· 已解';
    } else {
      en.textContent = 'UNSOLVED';
      en.className = 'mono case-meta__status is-unsolved';
      cn.textContent = '· 未解';
    }
  }

  document.querySelectorAll<HTMLElement>('[data-case-progress]').forEach(updateCaseProgressBadge);
  window.addEventListener('inferred:case-solved', () => {
    document.querySelectorAll<HTMLElement>('[data-case-progress]').forEach(updateCaseProgressBadge);
  });
</script>
