---
import BrandMark from './BrandMark.astro';

const year = new Date().getFullYear();
const nav = [
  { href: '/cases', cn: '案卷', en: 'Cases' },
  { href: '/clues', cn: '线索', en: 'Clues' },
  { href: '/archive', cn: '档案馆', en: 'Archive' },
  { href: '/about', cn: '关于', en: 'About' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__title">
        <BrandMark class="site-footer__logo" size={28} />
        <span
          >推知 Inferred<span class="text-accent">.</span><span class="text-muted">uk</span></span
        >
      </p>
      <p class="text-muted site-footer__tagline">
        <span class="i18n-zh">真相从不明说，只能被推断。</span>
        <span class="i18n-en">The truth is never stated. It is inferred.</span>
      </p>
      <p class="eyebrow">
        <span class="i18n-zh">The truth is never stated. It is inferred.</span>
        <span class="i18n-en">真相从不明说，只能被推断。</span>
      </p>
    </div>

    <nav class="site-footer__nav" aria-label="页脚导航">
      {nav.map((item) => (
        <a href={item.href}>
          <span class="i18n-zh">{item.cn}</span>
          <span class="i18n-en">{item.en}</span>
        </a>
      ))}
    </nav>
  </div>

  <div class="container site-footer__legal">
    <span class="mono">© {year} 推知 Inferred</span>
    <span class="text-muted">
      <span class="i18n-zh">原创互动推理案卷 · 一切人物与案件均属虚构</span>
      <span class="i18n-en">Original interactive mystery · All characters and events are fictional</span>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    /* 底部为 iOS Home 指示条留出安全区 */
    padding-block: var(--space-12) calc(var(--space-8) + env(safe-area-inset-bottom));
  }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .site-footer__title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin: 0 0 var(--space-2);
  }
  .site-footer__logo {
    flex-shrink: 0;
    display: block;
  }
  .site-footer__tagline {
    margin: 0 0 var(--space-1);
  }
  .site-footer__nav {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }
  .site-footer__nav a {
    color: var(--color-muted);
  }
  .site-footer__nav a:hover {
    color: var(--color-paper);
  }
  .site-footer__legal {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-line);
    font-size: 0.8rem;
    color: var(--color-muted);
  }
</style>
