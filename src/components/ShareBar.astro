---
export interface Props {
  /** 文章标题 */
  title: string;
  /** 一句话摘要，作为分享文案 */
  text?: string;
  /** 站内绝对路径，例如 /cases/xxx */
  path: string;
}

const { title, text = '', path } = Astro.props;
const url = new URL(path, Astro.site ?? 'https://inferred.uk').href;

// 微博分享 intent（无需 SDK，直接打开分享弹窗）
const weiboHref =
  'https://service.weibo.com/share/share.php?url=' +
  encodeURIComponent(url) +
  '&title=' +
  encodeURIComponent(`${title}｜Inferred`);
---

<aside
  class="share"
  data-share
  data-url={url}
  data-title={title}
  data-text={text}
  aria-label="分享这篇文章"
>
  <span class="share__label mono">分享 · SHARE</span>

  <div class="share__actions">
    <button type="button" class="share__btn share__btn--copy" data-share-copy>复制链接</button>
    <a
      class="share__btn"
      href={weiboHref}
      target="_blank"
      rel="noopener noreferrer"
      data-share-weibo
      aria-label={`分享到微博：${title}`}>微博</a
    >
    <button type="button" class="share__btn share__btn--more" data-share-native hidden>
      更多…
    </button>
  </div>

  <p class="share__toast mono" data-share-toast hidden aria-live="polite">链接已复制</p>
</aside>

<style>
  .share {
    margin-top: var(--space-12);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
  }
  .share__label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .share__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin-left: auto;
  }
  .share__btn {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: var(--color-paper);
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.45em 1em;
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  .share__btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
  .share__btn--copy {
    border-color: color-mix(in srgb, var(--color-accent) 60%, var(--color-line));
  }
  .share__btn--copy:hover {
    border-color: var(--color-accent);
    color: var(--color-paper);
    background: color-mix(in srgb, var(--color-accent) 22%, transparent);
  }
  .share__toast {
    flex-basis: 100%;
    margin: 0;
    text-align: right;
    font-size: 0.75rem;
    color: var(--color-gold);
  }

  @media (max-width: 560px) {
    .share {
      flex-direction: column;
      align-items: stretch;
    }
    .share__actions {
      margin-left: 0;
    }
    .share__btn {
      flex: 1 1 auto;
      text-align: center;
    }
    .share__toast {
      text-align: center;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-share]').forEach((root) => {
    const url = root.dataset.url ?? location.href;
    const title = root.dataset.title ?? document.title;
    const text = root.dataset.text ?? '';

    const toast = root.querySelector<HTMLElement>('[data-share-toast]');
    const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');

    const isWeChat = /MicroMessenger/i.test(navigator.userAgent);
    const canNativeShare = typeof navigator.share === 'function';

    function showToast(msg: string) {
      if (!toast) return;
      toast.textContent = msg;
      toast.hidden = false;
      window.setTimeout(() => {
        if (toast) toast.hidden = true;
      }, 2200);
    }

    async function nativeShare() {
      try {
        await navigator.share({ title, text, url });
        return true;
      } catch {
        return false;
      }
    }

    async function copyLink(message = '链接已复制') {
      try {
        await navigator.clipboard.writeText(url);
        showToast(message);
        return true;
      } catch {
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        try {
          document.execCommand('copy');
          showToast(message);
          return true;
        } catch {
          showToast('复制失败，请手动复制');
          return false;
        } finally {
          input.remove();
        }
      }
    }

    if (canNativeShare && nativeBtn) {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', nativeShare);
    }

    copyBtn?.addEventListener('click', async () => {
      if (isWeChat) {
        await copyLink('链接已复制');
        return;
      }
      if (canNativeShare) {
        const ok = await nativeShare();
        if (ok) return;
      }
      await copyLink('链接已复制，可在微信中打开后分享');
    });
  });
</script>