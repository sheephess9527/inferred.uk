---
export interface Props {
  title: string;
  text?: string;
  path: string;
  poster?: string;
}

const { title, text = '', path, poster } = Astro.props;
const site = Astro.site ?? 'https://inferred.uk';
const url = new URL(path, site).href;
const posterUrl = poster ?? '';

const weiboHref =
  'https://service.weibo.com/share/share.php?url=' +
  encodeURIComponent(url) +
  '&title=' +
  encodeURIComponent(`${title}｜Inferred`);
---

<aside
  class="share"
  data-share
  data-url={url}
  data-title={title}
  data-text={text}
  data-poster={posterUrl}
  aria-label="分享这篇文章"
>
  <span class="share__label mono">分享 · SHARE</span>

  <div class="share__actions">
    {
      poster && (
        <button type="button" class="share__btn share__btn--wechat" data-share-wechat>
          朋友圈
        </button>
      )
    }
    {
      poster && (
        <button type="button" class="share__btn share__btn--xhs" data-share-xhs>
          小红书
        </button>
      )
    }
    <a
      class="share__btn"
      href={weiboHref}
      target="_blank"
      rel="noopener noreferrer"
      data-share-weibo>微博</a
    >
    <button type="button" class="share__btn" data-share-copy>复制链接</button>
    <button type="button" class="share__btn share__btn--more" data-share-native hidden>更多…</button
    >
  </div>

  <p class="share__toast mono" data-share-toast hidden aria-live="polite"></p>
</aside>

{
  poster && (
    <div class="poster" data-poster-modal hidden aria-hidden="true">
      <div class="poster__backdrop" data-poster-close />
      <div class="poster__dialog" role="dialog" aria-modal="true" aria-label="分享海报">
        <button type="button" class="poster__x" data-poster-close aria-label="关闭">
          ✕
        </button>
        <ol class="poster__steps mono" data-poster-steps aria-label="操作步骤" />
        <div class="poster__frame" data-poster-frame>
          <img class="poster__img" data-poster-img alt={`${title} 分享海报`} />
        </div>
        <div class="poster__foot">
          <a class="poster__dl" data-poster-dl download>
            ↓ 下载图片
          </a>
          <a
            class="poster__action"
            data-poster-action
            target="_blank"
            rel="noopener noreferrer"
            hidden
          >
            去小红书
          </a>
        </div>
      </div>
    </div>
  )
}

<style>
  .share {
    margin-top: var(--space-12);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
  }
  .share__label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .share__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin-left: auto;
  }
  .share__btn {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: var(--color-paper);
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.45em 1em;
    cursor: pointer;
    text-decoration: none;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .share__btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
  .share__btn--wechat {
    border-color: color-mix(in srgb, var(--color-accent) 60%, var(--color-line));
  }
  .share__btn--wechat:hover {
    border-color: var(--color-accent);
    color: var(--color-paper);
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }
  .share__btn--xhs {
    border-color: color-mix(in srgb, #ff2e4d 50%, var(--color-line));
  }
  .share__btn--xhs:hover {
    border-color: #ff2e4d;
    color: #ff2e4d;
  }
  .share__toast {
    flex-basis: 100%;
    margin: 0;
    text-align: right;
    font-size: 0.75rem;
    color: var(--color-gold);
  }

  @media (max-width: 560px) {
    .share {
      flex-direction: column;
      align-items: stretch;
    }
    .share__actions {
      margin-left: 0;
    }
    .share__btn {
      flex: 1 1 auto;
      text-align: center;
    }
    .share__toast {
      text-align: center;
    }
  }

  /* 海报弹窗 */
  .poster[hidden] {
    display: none;
  }
  .poster {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
  }
  .poster__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(4px);
  }
  .poster__dialog {
    position: relative;
    z-index: 1;
    width: min(92vw, 22rem);
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    animation: poster-in 0.22s ease;
  }
  .poster__x {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-paper) 8%, transparent);
    color: var(--color-muted);
    font-size: 0.9rem;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  .poster__x:hover {
    color: var(--color-paper);
    background: color-mix(in srgb, var(--color-paper) 16%, transparent);
  }

  /* 步骤列表 */
  .poster__steps {
    margin: 0;
    padding-left: 1.4em;
    padding-right: 2rem;
    list-style: decimal;
    display: flex;
    flex-direction: column;
    gap: 0.35em;
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    color: var(--color-gold);
    line-height: 1.5;
  }

  /* 海报图区域 */
  .poster__frame {
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--radius) - 2px);
    border: 1px solid var(--color-line);
    background: #0e0e0c;
    min-height: 6rem;
  }
  .poster__frame[data-loading]::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 1.5rem;
    height: 1.5rem;
    border: 2px solid var(--color-line);
    border-top-color: var(--color-gold);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }
  .poster__img {
    display: block;
    width: 100%;
    height: auto;
  }
  .poster__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .poster__dl {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.4em 1em;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .poster__dl:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
  .poster__action {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: #ff2e4d;
    border: 1px solid #ff2e4d;
    border-radius: 999px;
    padding: 0.4em 1em;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .poster__action:hover {
    background: color-mix(in srgb, #ff2e4d 15%, transparent);
  }
  .poster__action[hidden] {
    display: none;
  }

  @keyframes poster-in {
    from {
      opacity: 0;
      transform: translateY(6px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-share]').forEach((root) => {
    const url = root.dataset.url ?? location.href;
    const title = root.dataset.title ?? document.title;
    const text = root.dataset.text ?? '';
    const poster = root.dataset.poster ?? '';

    const toast = root.querySelector<HTMLElement>('[data-share-toast]');
    const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');
    const wechatBtn = root.querySelector<HTMLButtonElement>('[data-share-wechat]');
    const xhsBtn = root.querySelector<HTMLButtonElement>('[data-share-xhs]');

    const modal = document.querySelector<HTMLElement>('[data-poster-modal]');
    const posterImg = modal?.querySelector<HTMLImageElement>('[data-poster-img]');
    const posterFrame = modal?.querySelector<HTMLElement>('[data-poster-frame]');
    const posterDl = modal?.querySelector<HTMLAnchorElement>('[data-poster-dl]');
    const posterAct = modal?.querySelector<HTMLAnchorElement>('[data-poster-action]');
    const posterSteps = modal?.querySelector<HTMLElement>('[data-poster-steps]');
    let lastFocus: HTMLElement | null = null;

    // 页面加载后立即预加载海报，用户点击时从缓存秒出
    if (poster) {
      const pre = new Image();
      pre.src = poster;
    }

    function showToast(msg: string) {
      if (!toast) return;
      toast.textContent = msg;
      toast.hidden = false;
      window.setTimeout(() => {
        if (toast) toast.hidden = true;
      }, 3000);
    }

    async function copyText(value: string): Promise<boolean> {
      if (typeof navigator !== 'undefined' && navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch {
          /* secure context or permission denied — try fallback */
        }
      }
      const el = Object.assign(document.createElement('textarea'), {
        value,
        style: 'position:fixed;left:-9999px;top:0',
        ariaHidden: 'true',
      });
      document.body.appendChild(el);
      el.focus();
      el.select();
      let ok = false;
      try {
        // Fallback for in-app browsers without Clipboard API
        if (
          typeof document.queryCommandSupported === 'function' &&
          document.queryCommandSupported('copy')
        ) {
          ok = Boolean(
            (document as Document & { execCommand(commandId: string): boolean }).execCommand('copy')
          );
        }
      } catch {
        ok = false;
      }
      el.remove();
      return ok;
    }

    // 在原海报上叠加判断题成绩条，返回 data URL；失败返回 null
    function buildScoredPosterDataUrl(
      baseUrl: string,
      score: { correct: number; evaluated: number }
    ): Promise<string | null> {
      return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
          const c = document.createElement('canvas');
          c.width = img.naturalWidth || 1200;
          c.height = img.naturalHeight || 630;
          const ctx = c.getContext('2d');
          if (!ctx) {
            resolve(null);
            return;
          }
          ctx.drawImage(img, 0, 0);

          const W = c.width;
          const H = c.height;
          // 0.16 → 渐变从 84% 处开始，低于二维码底部（约 80%），不遮挡扫码
          const barH = Math.round(H * 0.16);
          const py = H - barH;
          const px = Math.round(W * 0.055);

          // 渐变遮罩
          const grad = ctx.createLinearGradient(0, py, 0, H);
          grad.addColorStop(0, 'rgba(14,14,12,0)');
          grad.addColorStop(0.28, 'rgba(14,14,12,0.88)');
          grad.addColorStop(1, 'rgba(14,14,12,0.96)');
          ctx.fillStyle = grad;
          ctx.fillRect(0, py, W, barH);

          const isPerfect = score.evaluated > 0 && score.correct === score.evaluated;
          const scoreText = isPerfect
            ? `全部命中 · 推断了所有 ${score.evaluated} 道题`
            : `推断命中 ${score.correct} / ${score.evaluated} 题`;

          ctx.textAlign = 'left';
          ctx.textBaseline = 'alphabetic';

          // 成绩行
          ctx.font = `600 ${Math.round(W * 0.05)}px "Helvetica Neue",Arial,sans-serif`;
          ctx.fillStyle = isPerfect ? '#D4A853' : '#E8E2D2';
          ctx.fillText(scoreText, px, H - Math.round(barH * 0.4));

          // 邀请行
          ctx.font = `${Math.round(W * 0.032)}px "Helvetica Neue",Arial,sans-serif`;
          ctx.fillStyle = 'rgba(232,226,210,0.52)';
          ctx.fillText('你能看破真相吗？→ inferred.uk', px, H - Math.round(barH * 0.14));

          try {
            resolve(c.toDataURL('image/jpeg', 0.9));
          } catch {
            resolve(null);
          }
        };
        img.onerror = () => resolve(null);
        img.src = baseUrl;
      });
    }

    // 有成绩时返回叠加后的 data URL，否则返回原静态 URL（结果缓存一次）
    let _scoredSrc: string | null | undefined;
    async function getEffectivePosterSrc(): Promise<string> {
      if (!poster) return poster;
      if (_scoredSrc !== undefined) return _scoredSrc ?? poster;
      try {
        const raw = localStorage.getItem(`inferred:reveal:deduction:${location.pathname}`);
        if (raw) {
          const data = JSON.parse(raw) as { correct: number; evaluated: number };
          if (data.evaluated > 0) {
            _scoredSrc = await buildScoredPosterDataUrl(poster, data);
            return _scoredSrc ?? poster;
          }
        }
      } catch {}
      _scoredSrc = null;
      return poster;
    }

    function openPoster(opts: { steps: string[]; actionHref?: string; src?: string }) {
      if (!modal || !poster) return;

      const effectiveSrc = opts.src ?? poster;

      // src 变化时重新加载（首次或切换成绩版/静态版）
      if (posterImg && posterImg.getAttribute('src') !== effectiveSrc) {
        posterFrame?.setAttribute('data-loading', '');
        posterImg.onload = () => posterFrame?.removeAttribute('data-loading');
        posterImg.onerror = () => {
          posterFrame?.removeAttribute('data-loading');
          if (posterSteps) {
            posterSteps.innerHTML = '<li>海报加载失败，请稍后重试或直接复制链接</li>';
          }
        };
        posterImg.src = effectiveSrc;
      }

      if (posterDl) {
        posterDl.href = effectiveSrc;
        posterDl.setAttribute(
          'download',
          effectiveSrc.startsWith('data:')
            ? 'inferred-score.jpg'
            : (effectiveSrc.split('/').pop() || 'inferred.jpg')
        );
      }

      if (posterSteps) {
        posterSteps.innerHTML = opts.steps.map((s) => `<li>${s}</li>`).join('');
      }

      if (posterAct) {
        if (opts.actionHref) {
          posterAct.href = opts.actionHref;
          posterAct.hidden = false;
        } else {
          posterAct.hidden = true;
        }
      }

      lastFocus = document.activeElement as HTMLElement;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closePoster() {
      if (!modal) return;
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocus?.focus?.();
    }

    if (modal) {
      modal
        .querySelectorAll<HTMLElement>('[data-poster-close]')
        .forEach((el) => el.addEventListener('click', closePoster));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) closePoster();
      });
    }

    // 原生分享（仅在支持的浏览器上展示）
    if (typeof navigator.share === 'function' && nativeBtn) {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', () =>
        navigator.share({ title, text, url }).catch(() => {})
      );
    }

    copyBtn?.addEventListener('click', async () => {
      const ok = await copyText(url);
      showToast(ok ? '链接已复制' : '复制失败，请手动复制');
    });

    // 朋友圈：有成绩则叠加成绩条，否则用静态海报
    wechatBtn?.addEventListener('click', async () => {
      const src = await getEffectivePosterSrc();
      openPoster({
        src,
        steps: [
          '长按图片 → 保存到相册',
          '打开微信 → 发现 → 朋友圈',
          '点「相册」选刚保存的图，直接发布',
        ],
      });
    });

    // 小红书：先复制文案，再打开（有成绩时展示叠加版）
    xhsBtn?.addEventListener('click', async () => {
      const caption = [title, text, url, '#推理 #悬疑 #解谜 #本格推理 #Inferred']
        .filter(Boolean)
        .join('\n\n');
      const [copied, src] = await Promise.all([copyText(caption), getEffectivePosterSrc()]);

      openPoster({
        src,
        steps: [
          copied ? '✓ 文案已自动复制' : '手动复制文案（稍后粘贴）',
          '长按图片 → 保存到相册',
          '去小红书 → 新建笔记 → 选图 → 粘贴文案',
        ],
        actionHref: 'https://www.xiaohongshu.com',
      });
    });
  });
</script>
