---
export interface Props {
  title: string;
  text?: string;
  path: string;
  poster?: string;
}

const { title, text = '', path, poster } = Astro.props;
const site = Astro.site ?? 'https://inferred.uk';
const url = new URL(path, site).href;
const posterUrl = poster ? new URL(poster, site).href : '';

const weiboHref =
  'https://service.weibo.com/share/share.php?url=' +
  encodeURIComponent(url) +
  '&title=' +
  encodeURIComponent(`${title}｜Inferred`);
---

<aside class="share" data-share data-url={url} data-title={title} data-text={text} data-poster={posterUrl} aria-label="分享这篇文章">
  <span class="share__label mono">分享 · SHARE</span>

  <div class="share__actions">
    {poster && (
      <button type="button" class="share__btn share__btn--poster" data-share-poster>
        生成分享海报
      </button>
    )}
    <button type="button" class="share__btn" data-share-wechat>微信/朋友圈</button>
    {poster && (
      <button type="button" class="share__btn" data-share-xhs>去小红书</button>
    )}
    <a class="share__btn" href={weiboHref} target="_blank" rel="noopener noreferrer" data-share-weibo>微博</a>
    <button type="button" class="share__btn" data-share-copy>复制链接</button>
    <button type="button" class="share__btn" data-share-text>复制图文</button>
    <button type="button" class="share__btn share__btn--more" data-share-native hidden>更多…</button>
  </div>

  <p class="share__toast mono" data-share-toast hidden aria-live="polite">链接已复制</p>
</aside>

{poster && (
  <div class="poster" data-poster-modal hidden aria-hidden="true">
    <div class="poster__backdrop" data-poster-close></div>
    <div class="poster__dialog" role="dialog" aria-modal="true" aria-label="分享海报">
      <button type="button" class="poster__x" data-poster-close aria-label="关闭">✕</button>
      <p class="poster__hint mono" data-poster-hint>长按图片保存，或点击下方「下载图片」</p>
      <div class="poster__frame">
        <img class="poster__img" data-poster-img alt={`${title} 分享海报`} />
      </div>
      <div class="poster__foot">
        <a class="poster__dl" data-poster-dl download>下载图片</a>
        <span class="poster__note mono" data-poster-note></span>
      </div>
    </div>
  </div>
)}

<style>
  /* 样式部分保持不变，省略以节省空间 */
  .share { /* ... 你的原有样式 ... */ }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-share]').forEach((root) => {
    const url = root.dataset.url ?? location.href;
    const title = root.dataset.title ?? document.title;
    const text = root.dataset.text ?? '';
    const poster = root.dataset.poster ?? '';

    const toast = root.querySelector<HTMLElement>('[data-share-toast]');
    const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]');
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');
    const wechatBtn = root.querySelector<HTMLButtonElement>('[data-share-wechat]');
    const posterBtn = root.querySelector<HTMLButtonElement>('[data-share-poster]');
    const xhsBtn = root.querySelector<HTMLButtonElement>('[data-share-xhs]');
    const textBtn = root.querySelector<HTMLButtonElement>('[data-share-text]');

    const canNativeShare = typeof navigator.share === 'function';

    function showToast(msg: string) {
      if (!toast) return;
      toast.textContent = msg;
      toast.hidden = false;
      window.setTimeout(() => { if (toast) toast.hidden = true; }, 3200);
    }

    async function nativeShare() {
      try { await navigator.share({ title, text, url }); return true; }
      catch { return false; }
    }

    async function copyText(value: string) {
      try { await navigator.clipboard.writeText(value); return true; }
      catch {
        const input = document.createElement('textarea');
        input.value = value; input.style.position = 'fixed'; input.style.opacity = '0';
        document.body.appendChild(input); input.select();
        let ok = false; try { ok = document.execCommand('copy'); } catch { ok = false; }
        input.remove(); return ok;
      }
    }

    async function copyLink() {
      const ok = await copyText(url);
      showToast(ok ? '链接已复制' : '复制失败，请手动复制');
    }

    async function copyTextWithPoster() {
      let shareContent = `${title}\n\n`;
      if (text) shareContent += `${text}\n\n`;
      shareContent += `${url}`;
      if (poster) shareContent += `\n\n[分享海报] ${poster}`;
      shareContent += `\n\n#推理 #悬疑 #本格推理 #Inferred`;
      const ok = await copyText(shareContent);
      showToast(ok ? '图文已复制，可直接粘贴到小红书/朋友圈' : '复制失败');
    }

    if (canNativeShare && nativeBtn) {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener('click', nativeShare);
    }

    copyBtn?.addEventListener('click', copyLink);
    textBtn?.addEventListener('click', copyTextWithPoster);

    wechatBtn?.addEventListener('click', async () => {
      if (canNativeShare) {
        const ok = await nativeShare(); if (ok) return;
      }
      await copyLink();
      showToast('链接已复制。发朋友圈推荐点击「生成分享海报」');
    });

    posterBtn?.addEventListener('click', () =>
      openPoster({ hint: '长按图片保存，或点击下方「下载图片」' })
    );

    xhsBtn?.addEventListener('click', async () => {
      let shareContent = `${title}\n\n`;
      if (text) shareContent += `${text}\n\n`;
      shareContent += `${url}`;
      if (poster) shareContent += `\n\n[分享海报] ${poster}`;
      shareContent += `\n\n#推理 #悬疑 #本格推理 #Inferred`;
      const ok = await copyText(shareContent);
      showToast(ok ? '小红书图文已复制，可直接粘贴发布' : '复制失败');
      if (poster) {
        setTimeout(() => openPoster({ hint: '长按保存海报，粘贴文案即可发布', note: '文案已复制' }), 800);
      }
    });

    const modal = document.querySelector<HTMLElement>('[data-poster-modal]');
    const posterImg = modal?.querySelector<HTMLImageElement>('[data-poster-img]');
    const posterDl = modal?.querySelector<HTMLAnchorElement>('[data-poster-dl]');
    const posterNote = modal?.querySelector<HTMLElement>('[data-poster-note]');
    const posterHint = modal?.querySelector<HTMLElement>('[data-poster-hint]');
    let lastFocus: HTMLElement | null = null;

    function openPoster(opts?: { hint?: string; note?: string }) {
      if (!modal || !poster) return;
      if (posterImg) {
        posterImg.style.display = 'block';
        posterImg.onerror = () => {
          if (posterBtn) posterBtn.style.display = 'none';
          if (xhsBtn) xhsBtn.style.display = 'none';
          posterImg.style.display = 'none';
          if (posterHint) posterHint.textContent = '海报暂时无法显示，请稍后再试或直接复制链接';
        };
        if (!posterImg.src || posterImg.src === '') posterImg.src = poster;
      }
      if (posterDl) {
        posterDl.href = poster;
        posterDl.setAttribute('download', poster.split('/').pop() || 'inferred.jpg');
      }
      if (posterHint && opts?.hint) posterHint.textContent = opts.hint;
      if (posterNote) posterNote.textContent = opts?.note ?? '';
      lastFocus = document.activeElement as HTMLElement;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closePoster() {
      if (!modal) return;
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocus?.focus?.();
    }

    if (modal) {
      modal.querySelectorAll<HTMLElement>('[data-poster-close]').forEach(el => el.addEventListener('click', closePoster));
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) closePoster(); });
    }
  });
</script>
