---
// src/components/ProgressDashboard.astro
import { getSolvedCount } from '../lib/progress';

interface Props {
  totalCases: number;
}

const { totalCases } = Astro.props;
const solved = getSolvedCount();
const percentage = totalCases > 0 ? Math.round((solved / totalCases) * 100) : 0;
---

<div class="progress-dashboard">
  <div class="progress-header">
    <span class="progress-label">侦探档案</span>
    <span class="progress-stats">
      已结案 <strong>{solved}</strong> / {totalCases}
    </span>
  </div>
  <div class="progress-bar">
    <div class="progress-fill" style={`width: ${percentage}%`}></div>
  </div>
</div>

<style>
  .progress-dashboard {
    margin: var(--space-6) 0 var(--space-10);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    max-width: 420px;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .progress-label {
    letter-spacing: 0.02em;
  }

  .progress-stats {
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .progress-stats strong {
    color: var(--color-paper);
    font-weight: 500;
  }

  .progress-bar {
    height: 3px;
    background: var(--color-line);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-gold);
    transition: width 0.4s ease;
  }
</style>
