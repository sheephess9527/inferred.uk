---
// 互动物证板：点击每条物证可循环标记为 重要 / 可疑 / 误导 / 排除。
// 标记状态按 caseId 存入 localStorage，刷新后保留。
// 案卷揭晓后，对比作者预设的正确分类，给出每条物证的裁决与总评分。
export interface EvidenceItem {
  label: string;
  detail?: string;
  /** 作者设定的正确分类，不填则该物证不参与评分 */
  answer?: 'important' | 'suspicious' | 'misleading' | 'excluded';
}
export interface Props {
  caseId: string;
  items: EvidenceItem[];
}
const { caseId, items } = Astro.props;

/** 物证内容的稳定 ID，避免按数组下标存储导致内容增删后标记错位 */
function evidenceKey(label: string): string {
  let h = 5381;
  for (let i = 0; i < label.length; i++) {
    h = ((h << 5) + h) ^ label.charCodeAt(i);
  }
  return 'e' + (h >>> 0).toString(36);
}

const hasAnswers = items.some((item) => item.answer);
---

<section class="evidence" data-evidence aria-labelledby={`evidence-${caseId}`}>
  <header class="evidence__head">
    <p class="eyebrow" id={`evidence-${caseId}`}>物证 · Evidence</p>
    <p class="evidence__hint text-muted">
      <span class="i18n-zh">点击任一物证为它贴上标签：<span class="dot dot--important"></span>重要 · <span class="dot dot--suspicious"></span>可疑 · <span class="dot dot--misleading"></span>误导 · <span class="dot dot--excluded"></span>排除。标记会保存在本设备上。</span>
      <span class="i18n-en">Click any evidence to tag it: <span class="dot dot--important"></span>Important · <span class="dot dot--suspicious"></span>Suspicious · <span class="dot dot--misleading"></span>Misleading · <span class="dot dot--excluded"></span>Excluded. Tags are saved on this device.</span>
    </p>
    {hasAnswers && <p class="evidence__score mono" data-evidence-score hidden />}
  </header>

  <ol class="evidence__list">
    {
      items.map((item, i) => (
        <li class="evidence__item">
          <button
            type="button"
            class="evidence__btn"
            data-evidence-item
            data-index={i}
            data-evidence-key={evidenceKey(item.label)}
            data-case={caseId}
            data-answer={item.answer ?? undefined}
            aria-pressed="false"
          >
            <span class="evidence__num mono">{String(i + 1).padStart(2, '0')}</span>
            <span class="evidence__text">
              <span class="evidence__label">{item.label}</span>
              {item.detail && <span class="evidence__detail text-muted">{item.detail}</span>}
            </span>
            <span class="evidence__mark mono" data-evidence-mark aria-hidden="true">
              <span class="i18n-zh">未标记</span><span class="i18n-en">Unmarked</span>
            </span>
            {item.answer && (
              <span
                class="evidence__verdict mono"
                data-evidence-verdict
                hidden
                aria-hidden="true"
              />
            )}
          </button>
        </li>
      ))
    }
  </ol>

  <button type="button" class="evidence__reset mono" data-evidence-reset data-case={caseId}>
    <span class="i18n-zh">清除本案标记</span>
    <span class="i18n-en">Clear all marks</span>
  </button>
</section>

<style>
  .evidence {
    margin: var(--space-6) 0;
  }
  .evidence__head {
    margin-bottom: var(--space-4);
  }
  .evidence__hint {
    font-size: 0.85rem;
    margin: var(--space-2) 0 0;
  }
  .dot {
    display: inline-block;
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
    margin: 0 0.2em 0 0.5em;
    vertical-align: baseline;
  }
  .dot--important {
    background: var(--color-gold);
  }
  .dot--suspicious {
    background: var(--color-accent);
  }
  .dot--misleading {
    background: var(--color-accent-cold);
  }
  .dot--excluded {
    background: var(--color-muted);
  }

  /* 评分总结 */
  .evidence__score {
    margin-top: var(--space-3);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius);
    border: 1px solid var(--color-line);
    animation: score-in 0.4s ease;
  }
  .evidence__score[data-level='perfect'] {
    color: #6abf8a;
    background: color-mix(in srgb, #6abf8a 10%, transparent);
    border-color: color-mix(in srgb, #6abf8a 35%, var(--color-line));
  }
  .evidence__score[data-level='good'] {
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 8%, transparent);
    border-color: color-mix(in srgb, var(--color-gold) 35%, var(--color-line));
  }
  .evidence__score[data-level='low'] {
    color: var(--color-muted);
    background: transparent;
  }

  .evidence__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    counter-reset: none;
  }
  .evidence__btn {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    text-align: left;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-line);
    border-radius: var(--radius);
    color: var(--color-paper);
    cursor: pointer;
    font: inherit;
    transition:
      border-color 0.18s ease,
      background 0.18s ease;
  }
  .evidence__btn:hover {
    background: var(--color-surface-2);
  }
  /* 锁定后禁止交互与 hover 效果 */
  .evidence__btn[data-locked] {
    cursor: default;
  }
  .evidence__btn[data-locked]:hover {
    background: var(--color-surface);
  }
  .evidence__num {
    color: var(--color-muted);
    font-size: 0.8rem;
    padding-top: 0.25em;
  }
  .evidence__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }
  .evidence__label {
    line-height: 1.5;
  }
  .evidence__detail {
    font-size: 0.85rem;
  }
  .evidence__mark {
    flex-shrink: 0;
    align-self: center;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    padding: 0.3em 0.55em;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    color: var(--color-muted);
    white-space: nowrap;
  }

  /* 各标记状态：左边框 + 标签着色 */
  .evidence__btn[data-state='important'] {
    border-left-color: var(--color-gold);
  }
  .evidence__btn[data-state='important'] .evidence__mark {
    color: var(--color-gold);
    border-color: var(--color-gold);
  }
  .evidence__btn[data-state='suspicious'] {
    border-left-color: var(--color-accent);
  }
  .evidence__btn[data-state='suspicious'] .evidence__mark {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .evidence__btn[data-state='misleading'] {
    border-left-color: var(--color-accent-cold);
  }
  .evidence__btn[data-state='misleading'] .evidence__mark {
    color: var(--color-accent-cold);
    border-color: var(--color-accent-cold);
  }
  .evidence__btn[data-state='excluded'] {
    border-left-color: var(--color-muted);
    opacity: 0.6;
  }
  .evidence__btn[data-state='excluded'] .evidence__label {
    text-decoration: line-through;
  }

  /* 揭晓后裁决 badge */
  .evidence__verdict {
    flex-shrink: 0;
    align-self: center;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    padding: 0.3em 0.55em;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    white-space: nowrap;
    animation: verdict-in 0.3s ease both;
  }
  .evidence__verdict[data-verdict='correct'] {
    color: #6abf8a;
    border-color: color-mix(in srgb, #6abf8a 45%, var(--color-line));
  }
  .evidence__verdict[data-verdict='wrong'] {
    color: #e8a84c;
    border-color: color-mix(in srgb, #e8a84c 45%, var(--color-line));
  }
  .evidence__verdict[data-verdict='unmarked'] {
    color: var(--color-muted);
  }

  .evidence__reset {
    margin-top: var(--space-4);
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-muted);
    padding: 0.4em 0.8em;
    border-radius: var(--radius);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    cursor: pointer;
  }
  .evidence__reset:hover {
    color: var(--color-paper);
    border-color: var(--color-gold);
  }
  /* 揭晓后隐藏清除按钮 */
  .evidence[data-revealed] .evidence__reset {
    display: none;
  }

  @keyframes verdict-in {
    from {
      opacity: 0;
      transform: scale(0.85);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes score-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .evidence__verdict,
    .evidence__score {
      animation: none;
    }
  }
</style>

<script>
  type State = 'none' | 'important' | 'suspicious' | 'misleading' | 'excluded';
  const ORDER: State[] = ['none', 'important', 'suspicious', 'misleading', 'excluded'];
  const LABELS_ZH: Record<State, string> = {
    none: '未标记', important: '重要', suspicious: '可疑', misleading: '误导', excluded: '排除',
  };
  const LABELS_EN: Record<State, string> = {
    none: 'Unmarked', important: 'Important', suspicious: 'Suspicious', misleading: 'Misleading', excluded: 'Excluded',
  };
  function isEn() { return document.documentElement.getAttribute('data-lang') === 'en'; }
  function LABELS() { return isEn() ? LABELS_EN : LABELS_ZH; }
  function t(zh: string, en: string) { return isEn() ? en : zh; }

  const keyFor = (caseId: string) => `inferred:evidence:${caseId}`;
  const legacyKeyFor = (caseId: string) => `inferred:clues:${caseId}`;

  function load(caseId: string): Record<string, State> {
    try {
      const raw = localStorage.getItem(keyFor(caseId));
      return raw ? JSON.parse(raw) : {};
    } catch (e) {
      return {};
    }
  }

  function save(caseId: string, data: Record<string, State>) {
    try {
      localStorage.setItem(keyFor(caseId), JSON.stringify(data));
    } catch (e) {}
  }

  /** 将旧版按数组下标的标记迁移到按物证内容 hash 存储 */
  function migrateLegacy(caseId: string, buttons: NodeListOf<HTMLElement>): Record<string, State> {
    const current = load(caseId);
    if (Object.keys(current).length > 0) return current;

    try {
      const raw = localStorage.getItem(legacyKeyFor(caseId));
      if (!raw) return {};
      const legacy = JSON.parse(raw) as Record<string, State>;
      const migrated: Record<string, State> = {};

      buttons.forEach((btn) => {
        const idx = btn.dataset.index;
        const id = btn.dataset.evidenceKey;
        if (!idx || !id) return;
        const state = legacy[idx];
        if (state && state !== 'none') migrated[id] = state;
      });

      if (Object.keys(migrated).length > 0) {
        save(caseId, migrated);
        localStorage.removeItem(legacyKeyFor(caseId));
      }
      return migrated;
    } catch (e) {
      return {};
    }
  }

  function paint(btn: HTMLElement, state: State) {
    const mark = btn.querySelector<HTMLElement>('[data-evidence-mark]');
    if (state === 'none') {
      delete btn.dataset.state;
      btn.setAttribute('aria-pressed', 'false');
    } else {
      btn.dataset.state = state;
      btn.setAttribute('aria-pressed', 'true');
    }
    const label = LABELS()[state];
    if (mark) mark.textContent = label;
    const text = btn.querySelector('.evidence__label')?.textContent ?? '';
    btn.setAttribute('aria-label', t(
      `物证：${text}。当前标记：${label}。点击切换标记。`,
      `Evidence: ${text}. Current tag: ${label}. Click to cycle.`
    ));
  }

  /** 揭晓答案后：显示每条物证的裁决 + 总评分，并将结果写入 localStorage 供总结面板读取 */
  function revealFeedback(board: HTMLElement, buttons: NodeListOf<HTMLElement>, animate: boolean) {
    let evaluated = 0;
    let correct = 0;
    let marked = 0;

    buttons.forEach((btn, idx) => {
      const userState = (btn.dataset.state as State) ?? 'none';
      if (userState !== 'none') marked++;

      const answer = btn.dataset.answer as State | undefined;
      btn.dataset.locked = ''; // 全部锁定，不论是否有答案
      if (!answer) return;

      evaluated++;
      const verdictEl = btn.querySelector<HTMLElement>('[data-evidence-verdict]');
      const isCorrect = userState === answer;
      const isUnmarked = userState === 'none';

      if (isCorrect) correct++;

      if (verdictEl) {
        if (!animate) verdictEl.style.animation = 'none';
        else {
          verdictEl.style.animationDelay = `${idx * 60}ms`;
        }
        verdictEl.hidden = false;
        if (isCorrect) {
          verdictEl.textContent = t('✓ 正确', '✓ Correct');
          verdictEl.dataset.verdict = 'correct';
        } else if (isUnmarked) {
          verdictEl.textContent = t(`应为 ${LABELS_ZH[answer]}`, `Should be: ${LABELS_EN[answer]}`);
          verdictEl.dataset.verdict = 'unmarked';
        } else {
          verdictEl.textContent = t(`→ 实为 ${LABELS_ZH[answer]}`, `→ Should be: ${LABELS_EN[answer]}`);
          verdictEl.dataset.verdict = 'wrong';
        }
      }
    });

    // 将结果存入 localStorage，供 CaseSummary 读取
    try {
      localStorage.setItem(
        `inferred:reveal:evidence:${location.pathname}`,
        JSON.stringify({ marked, total: buttons.length, correct, evaluated })
      );
    } catch {}

    // 组件内评分横幅
    const scoreEl = board.querySelector<HTMLElement>('[data-evidence-score]');
    if (scoreEl && evaluated > 0) {
      if (!animate) scoreEl.style.animation = 'none';
      scoreEl.hidden = false;
      if (correct === evaluated) {
        scoreEl.textContent = t(
          `全部命中 · 准确识别了所有 ${evaluated} 个关键物证`,
          `Perfect — all ${evaluated} key evidence correctly tagged`
        );
        scoreEl.dataset.level = 'perfect';
      } else {
        scoreEl.textContent = t(
          `命中 ${correct} / ${evaluated} 个关键物证`,
          `Tagged ${correct} / ${evaluated} key evidence correctly`
        );
        scoreEl.dataset.level = correct >= evaluated / 2 ? 'good' : 'low';
      }
    }

    board.dataset.revealed = '';
  }

  document.querySelectorAll<HTMLElement>('[data-evidence]').forEach((board) => {
    const buttons = board.querySelectorAll<HTMLElement>('[data-evidence-item]');
    const caseId = buttons[0]?.dataset.case;
    if (!caseId) return;
    const stored = migrateLegacy(caseId, buttons);

    buttons.forEach((btn) => {
      const id = btn.dataset.evidenceKey!;
      paint(btn, stored[id] ?? 'none');
      btn.addEventListener('click', () => {
        if (btn.dataset.locked !== undefined) return; // 揭晓后锁定
        const current = (btn.dataset.state as State) ?? 'none';
        const next = ORDER[(ORDER.indexOf(current) + 1) % ORDER.length];
        paint(btn, next);
        const data = load(caseId);
        if (next === 'none') delete data[id];
        else data[id] = next;
        save(caseId, data);
      });
    });

    board
      .querySelector<HTMLButtonElement>('[data-evidence-reset]')
      ?.addEventListener('click', () => {
        if (!confirm(t('确定要清除本案所有物证标记吗？此操作无法撤销。', 'Clear all evidence tags for this case? This cannot be undone.'))) return;
        save(caseId, {});
        buttons.forEach((btn) => paint(btn, 'none'));
      });

    let isRevealed = false;

    // 如果案卷已经在之前的访问中揭晓，立即显示裁决（无动画）
    try {
      const progressKey = `inferred:progress:${location.pathname}`;
      if (localStorage.getItem(progressKey) === 'solved') {
        revealFeedback(board, buttons, false);
        isRevealed = true;
      }
    } catch (_) {}

    // 本次揭晓：有动画
    window.addEventListener('inferred:case-solved', () => {
      revealFeedback(board, buttons, true);
      isRevealed = true;
    });

    // 语言切换：重新绘制标签，如已揭晓则重新绘制裁决
    document.addEventListener('inferred:lang-changed', () => {
      const stored = load(caseId);
      buttons.forEach((btn) => {
        const id = btn.dataset.evidenceKey!;
        paint(btn, stored[id] ?? 'none');
      });
      if (isRevealed) revealFeedback(board, buttons, false);
    });
  });
</script>
