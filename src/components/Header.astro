---
import BrandMark from './BrandMark.astro';

const nav = [
  { href: '/cases', cn: '案卷', en: 'Cases' },
  { href: '/clues', cn: '线索', en: 'Clues' },
  { href: '/archive', cn: '档案馆', en: 'Archive' },
  { href: '/about', cn: '关于', en: 'About' },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || current.startsWith(href + '/');
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="推知 Inferred 首页">
      <BrandMark class="brand__logo" size={34} />
      <span class="brand__name">
        <span class="brand__cn">推知</span>
        <span class="brand__en">
          <span class="brand__mark">Inferred</span><span class="brand__dot" aria-hidden="true"
            >.</span
          ><span class="brand__tld">uk</span>
        </span>
      </span>
    </a>

    <nav class="site-nav" aria-label="主导航">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['site-nav__link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span class="site-nav__cn">{item.cn}</span>
                <span class="site-nav__en mono" aria-hidden="true">
                  {item.en}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-controls">
      <button
        type="button"
        class="lang-toggle mono"
        data-lang-toggle
        aria-label="切换语言 / Switch language"
        title="切换语言 / Switch language"
      >
        <span data-lang-label>EN</span>
      </button>
      <button
        type="button"
        class="theme-toggle mono"
        data-theme-toggle
        aria-label="切换亮色/暗色模式"
        title="切换亮色/暗色模式"
      >
        <span data-theme-icon>◑</span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
    /* 为 iOS 刘海 / 灵动岛 / 状态栏留出安全区，避免内容被画到状态栏底下点不到 */
    padding-top: env(safe-area-inset-top);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-height: 4rem;
    flex-wrap: nowrap;
    /* 横屏时避开左右刘海 */
    padding-inline: max(0px, env(safe-area-inset-left)) max(0px, env(safe-area-inset-right));
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-paper);
    margin-right: auto;
    flex-shrink: 0;
  }
  .brand__logo {
    flex-shrink: 0;
    display: block;
  }
  .brand__name {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand__cn {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
  }
  .brand__en {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    letter-spacing: 0.01em;
  }
  .site-nav {
    flex-shrink: 1;
    min-width: 0;
  }
  .brand__dot {
    color: var(--color-accent);
  }
  .brand__tld {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.82em;
  }
  .site-nav ul {
    display: flex;
    gap: var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-nav__link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.2;
    color: var(--color-muted);
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
  }
  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--color-paper);
  }
  .site-nav__link.is-active {
    border-bottom-color: var(--color-accent);
  }
  .site-nav__cn {
    font-size: 1rem;
  }
  .site-nav__en {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-line);
  }
  .site-nav__link:hover .site-nav__en,
  .site-nav__link.is-active .site-nav__en {
    color: var(--color-gold);
  }

  @media (max-width: 1100px) {
    .site-nav__en {
      display: none;
    }
  }
  .header-controls {
    display: flex;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .lang-toggle,
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-muted);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 0.78rem;
    line-height: 1;
    flex-shrink: 0;
    transition:
      color 0.18s ease,
      border-color 0.18s ease;
  }
  .theme-toggle {
    font-size: 1rem;
  }
  .lang-toggle:hover,
  .theme-toggle:hover {
    color: var(--color-paper);
    border-color: var(--color-gold);
  }

  /* EN mode: flip nav label prominence */
  :global([data-lang="en"]) .site-nav__cn {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-line);
  }
  :global([data-lang="en"]) .site-nav__en {
    display: block;
    font-size: 1rem;
    letter-spacing: normal;
    text-transform: none;
    color: inherit;
  }
  :global([data-lang="en"]) .site-nav__link:hover .site-nav__cn,
  :global([data-lang="en"]) .site-nav__link.is-active .site-nav__cn {
    color: var(--color-gold);
  }

  /* 平板与手机：导航独立一行、四栏等宽分布，避免与品牌挤在同一行 */
  @media (max-width: 960px) {
    .site-header__inner {
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-3) var(--space-4);
      padding-block: var(--space-3) var(--space-4);
    }
    .brand {
      margin-right: 0;
      gap: var(--space-2);
    }
    .brand__cn {
      font-size: 1.15rem;
    }
    .brand__en {
      font-size: 0.82rem;
    }
    .header-controls {
      order: 2;
      margin-left: auto;
    }
    .site-nav {
      order: 3;
      flex: 1 1 100%;
      width: 100%;
      padding-top: var(--space-2);
      border-top: 1px solid var(--color-line);
    }
    .site-nav ul {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--space-2);
      width: 100%;
    }
    .site-nav__en {
      display: none;
    }
    .site-nav__link {
      align-items: center;
      text-align: center;
      padding: var(--space-2) var(--space-1);
      min-height: 2.75rem;
      justify-content: center;
    }
    .site-nav__cn {
      font-size: 0.95rem;
      white-space: nowrap;
    }
  }

  @media (max-width: 400px) {
    .site-nav__cn {
      font-size: 0.88rem;
    }
  }
</style>

<script>
  // Language toggle
  const langToggle = document.querySelector<HTMLButtonElement>('[data-lang-toggle]');
  const langLabel = document.querySelector<HTMLElement>('[data-lang-label]');

  function currentLang(): 'en' | 'zh' {
    return document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'zh';
  }

  function applyLang(lang: 'en' | 'zh') {
    if (lang === 'en') {
      document.documentElement.setAttribute('data-lang', 'en');
      document.documentElement.lang = 'en';
    } else {
      document.documentElement.removeAttribute('data-lang');
      document.documentElement.lang = 'zh-CN';
    }
    if (langLabel) langLabel.textContent = lang === 'en' ? '中' : 'EN';
  }

  if (langLabel) langLabel.textContent = currentLang() === 'en' ? '中' : 'EN';

  langToggle?.addEventListener('click', () => {
    const next = currentLang() === 'en' ? 'zh' : 'en';
    applyLang(next);
    try {
      localStorage.setItem('inferred:lang', next);
    } catch (e) {}
  });

  // Theme toggle
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const icon = document.querySelector<HTMLElement>('[data-theme-icon]');

  function currentTheme(): 'light' | 'dark' {
    return document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
  }

  function paintIcon() {
    if (icon) icon.textContent = currentTheme() === 'light' ? '◐' : '◑';
  }

  function syncHeaderHeight() {
    if (!header) return;
    document.documentElement.style.setProperty(
      '--header-height',
      `${header.getBoundingClientRect().height}px`
    );
  }

  paintIcon();
  syncHeaderHeight();
  window.addEventListener('resize', syncHeaderHeight, { passive: true });
  if (typeof ResizeObserver !== 'undefined' && header) {
    new ResizeObserver(syncHeaderHeight).observe(header);
  }

  toggle?.addEventListener('click', () => {
    const next = currentTheme() === 'light' ? 'dark' : 'light';
    (window as unknown as { inferredApplyTheme?: (theme: string) => void }).inferredApplyTheme?.(
      next
    );
    try {
      localStorage.setItem('inferred:theme', next);
    } catch (e) {}
    paintIcon();
  });
</script>
