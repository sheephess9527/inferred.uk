---
const nav = [
  { href: '/cases', cn: '案卷', en: 'Cases' },
  { href: '/clues', cn: '线索', en: 'Clues' },
  { href: '/archive', cn: '档案馆', en: 'Archive' },
  { href: '/about', cn: '关于', en: 'About' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  current === href || current.startsWith(href + '/');
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="Inferred 首页">
      <span class="brand__mark">Inferred</span>
      <span class="brand__dot" aria-hidden="true">.</span>
      <span class="brand__tld">uk</span>
    </a>

    <nav class="site-nav" aria-label="主导航">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['site-nav__link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                <span class="site-nav__cn">{item.cn}</span>
                <span class="site-nav__en mono" aria-hidden="true">{item.en}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      type="button"
      class="theme-toggle mono"
      data-theme-toggle
      aria-label="切换亮色/暗色模式"
      title="切换亮色/暗色模式"
    >
      <span data-theme-icon>◑</span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
    /* 为 iOS 刘海 / 灵动岛 / 状态栏留出安全区，避免内容被画到状态栏底下点不到 */
    padding-top: env(safe-area-inset-top);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    min-height: 4rem;
    flex-wrap: wrap;
    /* 横屏时避开左右刘海 */
    padding-inline: max(0px, env(safe-area-inset-left)) max(0px, env(safe-area-inset-right));
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
    color: var(--color-paper);
    margin-right: auto;
  }
  .brand__dot {
    color: var(--color-accent);
  }
  .brand__tld {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .site-nav ul {
    display: flex;
    gap: var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-nav__link {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.2;
    color: var(--color-muted);
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
  }
  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--color-paper);
  }
  .site-nav__link.is-active {
    border-bottom-color: var(--color-accent);
  }
  .site-nav__cn {
    font-size: 1rem;
  }
  .site-nav__en {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-line);
  }
  .site-nav__link:hover .site-nav__en,
  .site-nav__link.is-active .site-nav__en {
    color: var(--color-gold);
  }
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-line);
    color: var(--color-muted);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .theme-toggle:hover {
    color: var(--color-paper);
    border-color: var(--color-gold);
  }

  @media (max-width: 560px) {
    .site-header__inner {
      gap: var(--space-2) var(--space-4);
      padding-block: var(--space-2) var(--space-3);
    }
    .brand {
      font-size: 1.1rem;
    }
    /* 品牌 + 主题键占第一行，导航整行换到下方，给足点击空间 */
    .theme-toggle {
      order: 2;
    }
    .site-nav {
      order: 3;
      flex-basis: 100%;
    }
    .site-nav ul {
      gap: var(--space-5);
      justify-content: flex-start;
    }
    .site-nav__en {
      display: none;
    }
    .site-nav__cn {
      font-size: 1.05rem;
    }
    .site-nav__link {
      padding: var(--space-2) 0;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const icon = document.querySelector<HTMLElement>('[data-theme-icon]');

  function currentTheme(): 'light' | 'dark' {
    return document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
  }

  function paintIcon() {
    if (icon) icon.textContent = currentTheme() === 'light' ? '◐' : '◑';
  }

  function syncHeaderHeight() {
    if (!header) return;
    document.documentElement.style.setProperty(
      '--header-height',
      `${header.getBoundingClientRect().height}px`
    );
  }

  paintIcon();
  syncHeaderHeight();
  window.addEventListener('resize', syncHeaderHeight, { passive: true });
  if (typeof ResizeObserver !== 'undefined' && header) {
    new ResizeObserver(syncHeaderHeight).observe(header);
  }

  toggle?.addEventListener('click', () => {
    const next = currentTheme() === 'light' ? 'dark' : 'light';
    (
      window as unknown as { inferredApplyTheme?: (theme: string) => void }
    ).inferredApplyTheme?.(next);
    try {
      localStorage.setItem('inferred:theme', next);
    } catch (e) {}
    paintIcon();
  });
</script>
