---
import DifficultyStars from './DifficultyStars.astro';
import Tag from './Tag.astro';

export interface Props {
  caseId: string;
  title: string;
  summary: string;
  difficulty: number;
  types: string[];
  readingTime: string;
  status: 'unsolved' | 'solved';
  slug: string;
}
const { caseId, title, summary, difficulty, types, readingTime, status, slug } = Astro.props;
const href = `/cases/${slug}`;
const statusCn = status === 'solved' ? '已解' : '未解';
---

<article class="case-card" data-case-slug={slug} data-site-status={status}>
  <a class="case-card__link" href={href} aria-label={`打开案卷 ${title}`} data-case-title={title}>
    <header class="case-card__head">
      <span class="case-card__id mono">Case #{caseId}</span>
      <span class:list={['tag', `tag--status-${status}`]} data-progress-badge>{statusCn}</span>
    </header>

    <h3 class="case-card__title">{title}</h3>
    <p class="case-card__summary">{summary}</p>

    <ul class="case-card__types">
      {
        types.map((t) => (
          <li>
            <Tag label={t} />
          </li>
        ))
      }
    </ul>

    <footer class="case-card__foot">
      <DifficultyStars value={difficulty} />
      <span class="case-card__time mono">{readingTime}</span>
      <span class="case-card__cta"><span class="i18n-zh">打开案卷 →</span><span class="i18n-en">Open case →</span></span>
    </footer>
  </a>
</article>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 13rem;
  }
  .case-card__link {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    color: inherit;
    position: relative;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      background 0.2s ease;
  }
  .case-card__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .case-card__link:hover {
    border-color: color-mix(in srgb, var(--color-gold) 40%, var(--color-line));
    background: var(--color-surface-2);
    transform: translateY(-2px);
  }
  .case-card__link:hover::before {
    opacity: 1;
  }
  .case-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .case-card__id {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .case-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin: 0;
    color: var(--color-paper);
    line-height: 1.3;
  }
  .case-card__summary {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .case-card__types {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-1) 0 0;
    padding: 0;
    list-style: none;
  }
  .case-card__foot {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-line);
    font-size: 0.85rem;
  }
  .case-card__time {
    color: var(--color-muted);
    font-size: 0.78rem;
  }
  .case-card__cta {
    margin-left: auto;
    color: var(--color-gold);
    font-size: 0.85rem;
    white-space: nowrap;
  }
</style>

<style>
  .case-card__summary {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* inline tag styles — badge rendered as plain span, not Tag component */
  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.35em 0.6em;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    color: var(--color-muted);
    background: transparent;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .tag--status-unsolved {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 50%, var(--color-line));
  }
  .tag--status-solved {
    color: var(--color-gold);
    border-color: color-mix(in srgb, var(--color-gold) 50%, var(--color-line));
  }
  .tag--status-reading {
    color: #e8a84c;
    border-color: color-mix(in srgb, #e8a84c 45%, var(--color-line));
  }
  .tag--status-user-solved {
    color: #6abf8a;
    border-color: color-mix(in srgb, #6abf8a 45%, var(--color-line));
  }
</style>

<script>
  function isEn() {
    return document.documentElement.getAttribute('data-lang') === 'en';
  }

  function updateProgressBadges() {
    const en = isEn();
    document.querySelectorAll<HTMLElement>('[data-case-slug]').forEach((card) => {
      const slug = card.dataset.caseSlug;
      const badge = card.querySelector<HTMLElement>('[data-progress-badge]');
      const link = card.querySelector<HTMLElement>('[data-case-title]');
      if (!badge || !slug) return;
      const siteStatus = card.dataset.siteStatus === 'solved' ? 'solved' : 'unsolved';
      const title = link?.dataset.caseTitle ?? '';
      if (link) link.setAttribute('aria-label', en ? `Open case: ${title}` : `打开案卷 ${title}`);
      try {
        const progress = localStorage.getItem(`inferred:progress:/cases/${slug}`);
        if (progress === 'solved') {
          badge.textContent = en ? 'CLOSED' : '已结案';
          badge.className = 'tag tag--status-user-solved';
        } else if (progress === 'reading') {
          badge.textContent = en ? 'ACTIVE' : '推理中';
          badge.className = 'tag tag--status-reading';
        } else if (siteStatus === 'solved') {
          badge.textContent = en ? 'SOLVED' : '已解';
          badge.className = 'tag tag--status-solved';
        } else {
          badge.textContent = en ? 'UNSOLVED' : '未解';
          badge.className = 'tag tag--status-unsolved';
        }
      } catch (_) {}
    });
  }
  updateProgressBadges();
  window.addEventListener('inferred:case-solved', updateProgressBadges);
  document.addEventListener('inferred:lang-changed', updateProgressBadges);
</script>
