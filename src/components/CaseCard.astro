---
import DifficultyStars from './DifficultyStars.astro';
import Tag from './Tag.astro';

export interface Props {
  caseId: string;
  title: string;
  summary: string;
  difficulty: number;
  types: string[];
  readingTime: string;
  status: 'unsolved' | 'solved';
  slug: string;
}
const { caseId, title, summary, difficulty, types, readingTime, status, slug } =
  Astro.props;
const href = `/cases/${slug}`;
const statusCn = status === 'solved' ? '已解' : '未解';
---

<article class="case-card">
  <a class="case-card__link" href={href} aria-label={`打开案卷 ${title}`}>
    <header class="case-card__head">
      <span class="case-card__id mono">Case #{caseId}</span>
      <Tag label={statusCn} variant={`status-${status}`} />
    </header>

    <h3 class="case-card__title">{title}</h3>
    <p class="case-card__summary">{summary}</p>

    <ul class="case-card__types">
      {types.map((t) => <li><Tag label={t} /></li>)}
    </ul>

    <footer class="case-card__foot">
      <DifficultyStars value={difficulty} />
      <span class="case-card__time mono">{readingTime}</span>
      <span class="case-card__cta">打开案卷 →</span>
    </footer>
  </a>
</article>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 13rem;
  }
  .case-card__link {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-3);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    color: inherit;
    position: relative;
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }
  .case-card__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .case-card__link:hover {
    border-color: color-mix(in srgb, var(--color-gold) 40%, var(--color-line));
    background: var(--color-surface-2);
    transform: translateY(-2px);
  }
  .case-card__link:hover::before {
    opacity: 1;
  }
  .case-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .case-card__id {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .case-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    margin: 0;
    color: var(--color-paper);
    line-height: 1.3;
  }
  .case-card__summary {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .case-card__types {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-1) 0 0;
    padding: 0;
    list-style: none;
  }
  .case-card__foot {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-line);
    font-size: 0.85rem;
  }
  .case-card__time {
    color: var(--color-muted);
    font-size: 0.78rem;
  }
  .case-card__cta {
    margin-left: auto;
    color: var(--color-gold);
    font-size: 0.85rem;
    white-space: nowrap;
  }
</style>

<style>
  .case-card__summary {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>