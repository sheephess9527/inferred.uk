---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import UpdatePrompt from '../components/UpdatePrompt.astro';

export interface Props {
  title: string;
  description: string;
  /** 相对路径，例如 "/cases/third-cup-in-the-rainy-inn" */
  path?: string;
  /** 分享卡片标题（朋友圈 / 微信链接预览）；默认与 title 相同 */
  ogTitle?: string;
  ogImage?: string;
  /** 分享图 alt 文案 */
  ogImageAlt?: string;
  /** Open Graph 类型：首页等用 website，案卷/线索详情用 article */
  ogType?: 'website' | 'article';
  /** ISO 8601 发布时间，用于 article 页面 */
  publishedTime?: string;
  /** JSON-LD 结构化数据对象 */
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogTitle = title,
  ogImage = '/og-default.jpg',
  ogImageAlt = '推知 Inferred — 真相从不明说，只能被推断',
  ogType = 'website',
  publishedTime,
  jsonLd,
  noindex = false,
} = Astro.props;

const siteName = '推知 Inferred';
const siteOrigin = Astro.site ?? 'https://inferred.uk';
const canonical = new URL(path, siteOrigin).href;
const ogImageUrl = new URL(ogImage, siteOrigin).href;
const ogImageType = ogImage.endsWith('.png') ? 'image/png' : 'image/jpeg';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- 添加到主屏幕（iOS / Android） -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0E0E0C" id="meta-theme-color" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
      id="meta-status-bar"
    />
    <meta name="apple-mobile-web-app-title" content="推知" />
    <meta name="application-name" content="推知" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / 微信·微博链接卡片 -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- 微信等爬虫备用字段 -->
    <meta itemprop="name" content={ogTitle} />
    <meta itemprop="description" content={description} />
    <meta itemprop="image" content={ogImageUrl} />
    <link rel="image_src" href={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- 主题在首帧前确定，避免闪烁；同步浏览器/PWA 顶栏颜色 -->
    <script is:inline>
      (function () {
        var THEME_COLORS = { dark: '#0E0E0C', light: '#E8E2D2' };
        var STATUS_BAR = { dark: 'black-translucent', light: 'default' };
        window.inferredApplyTheme = function (theme) {
          var resolved = theme === 'light' ? 'light' : 'dark';
          document.documentElement.dataset.theme = resolved;
          var themeColor = document.getElementById('meta-theme-color');
          var statusBar = document.getElementById('meta-status-bar');
          if (themeColor) themeColor.setAttribute('content', THEME_COLORS[resolved]);
          if (statusBar) statusBar.setAttribute('content', STATUS_BAR[resolved]);
        };
        try {
          var saved = localStorage.getItem('inferred:theme');
          if (saved === 'light' || saved === 'dark') {
            window.inferredApplyTheme(saved);
          } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            window.inferredApplyTheme('light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <UpdatePrompt />
  </body>
</html>
